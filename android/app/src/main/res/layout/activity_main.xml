<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Normal browsing layer: address bar + home WebView -->
    <LinearLayout
        android:id="@+id/browseLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#1a1a1a">

            <EditText
                android:id="@+id/addressBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:hint="输入网址"
                android:background="@android:color/transparent" />

            <Button
                android:id="@+id/goButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="前往" />
        </LinearLayout>

        <WebView
            android:id="@+id/homeWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <Button
        android:id="@+id/tiktokModeBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="🎵 抖音模式"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF0050" />

    <!-- Fullscreen swipe layer -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/videoPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/closeTiktokBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:visibility="gone" />

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Normal browsing layer: address bar + home WebView. Hidden by default;
         the app launches straight into TikTok mode. -->
    <LinearLayout
        android:id="@+id/browseLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#1a1a1a">

            <EditText
                android:id="@+id/addressBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:hint="输入网址"
                android:background="@android:color/transparent" />

            <Button
                android:id="@+id/goButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="前往" />
        </LinearLayout>

        <WebView
            android:id="@+id/homeWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- "Enter TikTok mode" button, only visible while in normal mode. -->
    <Button
        android:id="@+id/tiktokModeBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="🎵 抖音模式"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF0050"
        android:visibility="gone" />

    <!-- Fullscreen swipe layer: the default view on launch. -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/videoPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Startup / collecting indicator shown over the empty feed. -->
    <TextView
        android:id="@+id/startupText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="正在加载视频…"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <!-- "Switch to normal mode" toggle, visible while in TikTok mode. -->
    <Button
        android:id="@+id/normalModeBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:text="🌐 普通模式"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:backgroundTint="#80000000" />

</FrameLayout>

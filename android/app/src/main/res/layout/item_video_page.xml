<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <WebView
        android:id="@+id/itemWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Per-item loading spinner -->
    <ProgressBar
        android:id="@+id/loadingSpinner"
        style="?android:attr/progressBarStyle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent" />

    <!-- Transparent tap layer: toggles unmute / pause without exposing the page's own UI -->
    <View
        android:id="@+id/tapLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Big play icon shown when paused -->
    <ImageView
        android:id="@+id/playIcon"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_gravity="center"
        android:alpha="0.85"
        android:src="@drawable/ic_play_arrow"
        android:visibility="gone"
        android:contentDescription="播放" />

    <!-- Right action rail -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="120dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageButton
            android:id="@+id/muteBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_circle_translucent"
            android:scaleType="centerInside"
            android:padding="11dp"
            android:src="@drawable/ic_volume_off"
            android:contentDescription="静音" />

        <ImageButton
            android:id="@+id/reloadBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_translucent"
            android:scaleType="centerInside"
            android:padding="11dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="重载" />
    </LinearLayout>

    <!-- Bottom scrim + title -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/scrim_bottom" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="80dp"
        android:paddingBottom="34dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="轻触开启声音 · 上滑看下一个"
            android:textColor="@color/on_surface_muted"
            android:textSize="12sp" />
    </LinearLayout>

</FrameLayout>
